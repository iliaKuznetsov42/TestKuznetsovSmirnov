<Page x:Class="TestKuznetsovSmirnov.View.Pages.AddStudent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestKuznetsovSmirnov.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="370" d:DesignWidth="800"
      Title="AddStudent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="15" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="Введите ФИО:" Grid.Row="1" FontSize="25" VerticalAlignment="Center"/>
        <TextBox Name="EnterStudentTb" Grid.Row="1" Grid.Column="2"/>
        <Button Name="AddStudentBtn" Content="Добавить" Grid.Row="3" Click="AddStudentBtn_Click"/>
        <Button Name="BackBtn" Content="Назад" Grid.Row="3" Grid.Column="2" Click="BackBtn_Click"/>
    </Grid>
</Page>
