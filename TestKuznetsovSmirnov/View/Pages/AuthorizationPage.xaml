<Page x:Class="TestKuznetsovSmirnov.View.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestKuznetsovSmirnov.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorizationPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Светлана Дмитриевна, введите пароль:" Grid.Row="1" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <PasswordBox Name="TeachPsw" Grid.Row="3" Width="350"  />
        <Button Name="OkBtn" Grid.Row="5" Width="100" Content="Ок" FontSize="20" Click="OkBtn_Click"/>
    </Grid>
</Page>

