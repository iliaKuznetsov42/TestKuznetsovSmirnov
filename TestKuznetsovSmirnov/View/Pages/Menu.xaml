<Page x:Class="TestKuznetsovSmirnov.View.Pages.Menu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestKuznetsovSmirnov.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Menu">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Button Name="AddStudentBtn" Content="Добавить студента" Width="450" Height="50" Click="AddStudentBtn_Click"/>
        <Button Name="AddGroupBtn" Content="Добавить группу" Width="450" Height="50" Grid.Row="1" Click="AddGroupBtn_Click"/>
        <Button Name="StudentListBtn" Content="Список студентов с оценками" Width="450" Height="50" Grid.Row="2" Click="StudentListBtn_Click"/>
        <Button Name="DeleteStudentBtn" Content="Удалить студента" Width="450" Height="50" Grid.Row="3" Click="DeleteStudentBtn_Click"/>
        <Button Name="BackBtn" Width="450" Content="Выйти в главное меню" Height="50" Grid.Row="4" Click="BackBtn_Click"/>
    </Grid>
</Page>
