<Page x:Class="TestKuznetsovSmirnov.View.Pages.RegistrationStudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestKuznetsovSmirnov.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrationStudentPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="10" />

        </Grid.RowDefinitions>
        <TextBlock Text="Выберите группу" Grid.Row="1" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <ComboBox Name="GroupCmb"  Grid.Row="3" Width="200" SelectionChanged="GroupCmb_SelectionChanged"/>

        <TextBlock Text="Выберите студента" Grid.Row="5" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <ComboBox Name="StudentCmb"  Grid.Row="7" Width="200"/>

        <TextBlock Text="Выберите тест" Grid.Row="9" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <ComboBox Name="TestCmb"  Grid.Row="11" Width="200"/>

        <Button Name="StartBtn" Grid.Row="13" Width="150" Content="Начать" FontSize="20" Click="StartBtn_Click"/>
    </Grid>
</Page>
