<Page x:Class="TestKuznetsovSmirnov.View.Pages.AddGroup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestKuznetsovSmirnov.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddGroup">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Button Name="AddBtn" Click="AddBtn_Click" Content="Добавить" FontSize="20" Grid.Row="3" Grid.Column="0"/>
        <Button Name="BackBtn" Content="Назад" Grid.Column="2" Grid.Row="3" FontSize="20" Click="BackBtn_Click"/>
        <TextBlock Text="Введите группу:" Grid.Row="1" FontSize="30"/>
        <TextBox Name="NameGroupTb" Grid.Column="2" Grid.Row="1"/>
    </Grid>
</Page>
